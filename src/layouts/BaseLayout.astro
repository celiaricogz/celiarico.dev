---
import ContactModal from "../components/ui/ContactModal.astro";
import StoryRail from "../components/ui/StoryRail.astro";
import TopNav from "../components/ui/TopNav.astro";
import "../styles/global.css";
import logoImg from "../assets/ChatGPT Image Jul 14, 2026, 02_03_10 PM(1).png";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "IT Architect specialising in Platform Engineering, DevOps and Cloud. Helping technical teams modernise complex systems through structured engineering and architectural clarity.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Celia Rico",
  url: Astro.site,
});

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Celia Rico",
  jobTitle: "IT Architect",
  url: Astro.site,
  email: "hola@celiarico.dev",
  sameAs: ["https://www.linkedin.com/in/celiarico/"],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Celia Rico" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Google Fonts: Hanken Grotesk, IBM Plex Mono, Newsreader -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&family=Newsreader:ital,wght@1,400&display=swap"
    />
    <script type="application/ld+json" set:html={websiteSchema} />
    <script type="application/ld+json" set:html={personSchema} />
    <script is:inline>
      (function () {
        try {
          var theme = window.localStorage.getItem("cr-theme-v2");
          if (theme !== "dark" && theme !== "light") {
            theme =
              window.matchMedia &&
              window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          }
          if (theme === "dark") {
            document.documentElement.setAttribute("data-theme", "dark");
          }
          var lang = window.localStorage.getItem("cr-lang");
          if (lang === "es" || lang === "en") {
            document.documentElement.setAttribute("lang", lang);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link" lang="en">Skip to content</a>
    <a href="#main" class="skip-link" lang="es">Saltar al contenido</a>
    <StoryRail />
    <TopNav />
    <ContactModal />

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <button
          data-target="hero"
          class="site-footer__logo"
          aria-label="Back to top"
        >
          <span class="site-footer__logo-icon" aria-hidden="true">
            <img src={logoImg.src} alt="" class="site-footer__logo-img" />
          </span>
          <span class="site-footer__logo-text">
            <span class="site-footer__name">Celia Rico</span>
            <span class="site-footer__title" lang="en">IT Architect</span>
            <span class="site-footer__title" lang="es">Arquitecta IT</span>
          </span>
        </button>
        <span class="site-footer__copy">© 2026 Celia Rico</span>
        <button data-target="hero" class="site-footer__back-top">
          <span lang="en">Back to top ↑</span>
          <span lang="es">Volver arriba ↑</span>
        </button>
      </div>
    </footer>
  </body>
</html>

<script>
  import { initInteractions } from "../scripts/interactions";
  document.addEventListener("DOMContentLoaded", () => initInteractions());
</script>

<style>
  .skip-link {
    position: absolute;
    left: 12px;
    top: -60px;
    z-index: 200;
    padding: 10px 16px;
    background: var(--ink);
    color: var(--bg);
    border-radius: 8px;
    font: 600 13px/1 var(--font-body);
    text-decoration: none;
    transition: top 0.2s;
  }

  .skip-link:focus-visible {
    top: 12px;
  }

  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--line);
    padding: 32px clamp(1.25rem, 4vw, 3.5rem);
  }

  .site-footer__inner {
    max-width: 1240px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .site-footer__logo {
    all: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .site-footer__logo-icon {
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: linear-gradient(150deg, var(--accent), var(--accent-2));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .site-footer__logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .site-footer__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .site-footer__name {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
  }

  .site-footer__title {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-top: 5px;
  }

  .site-footer__copy {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .site-footer__back-top {
    all: unset;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--ink2);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    transition: color 0.3s;
  }

  .site-footer__back-top:hover {
    color: var(--accent);
  }

  /* Three flex items with space-between wrap awkwardly at narrow widths.
     Stack them centred so the footer reads as a coherent column. */
  @media (max-width: 540px) {
    .site-footer__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }
  }
</style>
