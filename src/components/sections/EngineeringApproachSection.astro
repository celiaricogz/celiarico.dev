---
import ProcessTimeline from "../features/patterns/ProcessTimeline.astro";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  id?: string;
}

const { id } = Astro.props;

const steps = [
  {
    stepNumber: "01",
    tagEn: "UNDERSTAND",
    tagEs: "ENTENDER",
    titleEn: "Build an accurate model of how the system actually works.",
    titleEs:
      "Construir un modelo preciso de cómo funciona realmente el sistema.",
    bodyEn:
      "Not how it was designed to work — how it behaves in production, under real conditions.",
    bodyEs:
      "No cómo se diseñó, sino cómo se comporta en producción, en condiciones reales.",
  },
  {
    stepNumber: "02",
    tagEn: "ANALYSE",
    tagEs: "ANALIZAR",
    titleEn:
      "Find the root cause, not the symptom — the analysis follows evidence, not the first hypothesis.",
    titleEs:
      "Encontrar la causa raíz, no el síntoma — el análisis sigue la evidencia, no la primera hipótesis.",
    bodyEn: "",
    bodyEs: "",
  },
  {
    stepNumber: "03",
    tagEn: "DESIGN",
    tagEs: "DISEÑAR",
    titleEn: "Shape the solution around the actual constraints.",
    titleEs: "Dar forma a la solución según las restricciones reales.",
    bodyEn:
      "Business priorities, team capacity, debt tolerance, time horizon — these define the solution space first. Architecture comes before technology; the technology serves it.",
    bodyEs:
      "Prioridades del negocio, capacidad del equipo, tolerancia a la deuda técnica, plazos: eso define primero el espacio de la solución. La arquitectura va antes que la tecnología.",
  },
  {
    stepNumber: "04",
    tagEn: "IMPLEMENT",
    tagEs: "IMPLEMENTAR",
    titleEn:
      "Change incrementally, and validate as you go — never trading complexity for complexity elsewhere.",
    titleEs:
      "Cambiar poco a poco y validar en cada paso — nunca cambiando complejidad por complejidad en otro lado.",
    bodyEn: "",
    bodyEs: "",
  },
  {
    stepNumber: "05",
    tagEn: "EVOLVE",
    tagEs: "EVOLUCIONAR",
    titleEn: "Leave the system easier to evolve than you found it.",
    titleEs: "Dejar el sistema más fácil de evolucionar de lo que se encontró.",
    bodyEn:
      "Deployment isn't completion. The real measure: does the team understand the system better than before, and is the next change easier to make? That's the standard — not the delivery date.",
    bodyEs:
      "El despliegue no es el final. La medida real: ¿el equipo entiende mejor el sistema que antes? ¿es más fácil el próximo cambio? Ese es el estándar, no la fecha de entrega.",
  },
];
---

<section id={id} aria-labelledby="approach-heading" class="approach-section">
  <div class="approach-section__inner">
    <SectionLabel label="02 — The Approach" counter="02 / 05" />

    <h2
      data-reveal
      data-d="60"
      id="approach-heading"
      class="approach-section__headline"
    >
      <span lang="en"
        >A deliberate path from uncertainty to a system you trust.</span
      >
      <span lang="es"
        >Un camino deliberado de la incertidumbre a un sistema en el que
        confías.</span
      >
    </h2>

    <p data-reveal data-d="120" class="approach-section__lead">
      <span lang="en"
        >Engineering is the process of reducing uncertainty until the right
        action becomes obvious. Every phase below follows from that.</span
      >
      <span lang="es"
        >La ingeniería es el proceso de reducir la incertidumbre hasta que la
        acción correcta resulta obvia. Cada fase parte de ahí.</span
      >
    </p>

    <ProcessTimeline items={steps} />

    <div data-reveal data-d="80" class="approach-section__commitment">
      <p class="approach-section__commitment-text">
        <span lang="en"
          >Technology is chosen after the architecture — never before. The goal
          isn't picking tools; it's leaving the system easier to understand,
          evolve, and operate.</span
        >
        <span lang="es"
          >La tecnología se elige después de la arquitectura, nunca antes. No se
          trata de elegir herramientas, sino de dejar el sistema más fácil de
          entender, evolucionar y operar.</span
        >
      </p>
    </div>
  </div>
</section>

<style>
  .approach-section {
    position: relative;
    z-index: 1;
    padding: clamp(6rem, 12vh, 9.375rem) clamp(1.25rem, 4vw, 3.5rem);
    background: var(--bg2);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .approach-section__inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .approach-section__headline {
    margin: 0 0 22px;
    max-width: 760px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.75rem, 4.2vw, 3.125rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .approach-section__lead {
    margin: 0 0 68px;
    max-width: 600px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink2);
  }

  .approach-section__commitment {
    margin-top: 56px;
    padding: 30px 32px;
    border-radius: 18px;
    background: linear-gradient(160deg, var(--accent), var(--accent-2));
  }

  .approach-section__commitment-text {
    margin: 0;
    max-width: 760px;
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 1.8vw, 1.3125rem);
    line-height: 1.55;
    color: #fff;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
</style>
