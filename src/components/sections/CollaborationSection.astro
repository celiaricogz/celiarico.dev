---
import PrincipleGrid from "../features/patterns/PrincipleGrid.astro";
import ServiceGrid from "../features/patterns/ServiceGrid.astro";
import Container from "../primitives/Container.astro";
import Stack from "../primitives/Stack.astro";
import Heading from "../typography/Heading.astro";
import Lead from "../typography/Lead.astro";

interface Props {
  id?: string;
}

const { id } = Astro.props;

const services = [
  {
    title: "Legacy Modernisation",
    description:
      "Helping organisations evolve complex systems safely, reducing operational risk and recovering architectural clarity without disrupting ongoing delivery.",
  },
  {
    title: "DevOps and Platform Engineering",
    description:
      "Improving delivery processes through infrastructure automation, deployment pipeline design and developer platform evolution.",
  },
  {
    title: "Architecture and Technical Guidance",
    description:
      "Supporting engineering teams and technical leadership during complex architectural decisions, technology transitions and system redesign.",
  },
  {
    title: "Long-Term Technical Collaboration",
    description:
      "Ongoing engineering support through predefined availability, providing architectural continuity and technical guidance as the organisation evolves.",
  },
];

const principles = [
  {
    statement: "Understanding before implementation",
    elaboration: "No system should be changed before it is understood.",
  },
  {
    statement: "Architecture before technology",
    elaboration:
      "Technology is selected to serve the architecture, not to define it.",
  },
  {
    statement: "Simplicity before complexity",
    elaboration:
      "The right solution is the simplest one that actually solves the problem.",
  },
  {
    statement: "Sustainable evolution over quick fixes",
    elaboration:
      "Every change should leave the system easier to understand and evolve than before.",
  },
];
---

<section id={id} aria-labelledby="collaboration-heading" class="py-section-md">
  <Container>
    <Stack gap="12">
      <Stack gap="6">
        <Heading level={2} id="collaboration-heading">
          How we can work together
        </Heading>
        <Lead>
          Every engagement begins by understanding the organisation's specific
          situation. The collaboration adapts to the project — not the other way
          around.
        </Lead>
      </Stack>
      <ServiceGrid items={services} />
      <PrincipleGrid items={principles} />
    </Stack>
  </Container>
</section>
