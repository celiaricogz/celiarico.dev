---
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  id?: string;
}

const { id } = Astro.props;

const cases = [
  {
    tagEn: "Platform Engineering",
    tagEs: "Ingeniería de plataforma",
    titleEn: "A deployment platform analysed, redesigned, and delivered.",
    titleEs: "Una plataforma de despliegue analizada, rediseñada y entregada.",
    contextEn:
      "A WebLogic platform needed modernising without disrupting existing deployments.",
    contextEs:
      "Una plataforma WebLogic necesitaba modernizarse sin frenar los despliegues en marcha.",
    decisionEn:
      "A Shared Jenkins Library centralised the deployment logic; compatibility layers preserved what had to stay unchanged.",
    decisionEs:
      "Una Shared Jenkins Library centralizó la lógica de despliegue; las capas de compatibilidad mantuvieron intacto lo que debía seguir igual.",
    outcomeEn: "Delivered on schedule.",
    outcomeEs: "Entregada según lo previsto.",
    delay: 60,
  },
  {
    tagEn: "Enterprise Architecture",
    tagEs: "Arquitectura empresarial",
    titleEn: "Architecture reviews across multiple engineering teams.",
    titleEs: "Revisiones de arquitectura en varios equipos de ingeniería.",
    contextEn:
      "Reviewing solution architectures and migration strategies across several teams at once.",
    contextEs:
      "Revisando arquitecturas de solución y estrategias de migración en varios equipos a la vez.",
    decisionEn:
      "When the evidence doesn't support a migration, that conclusion is documented — not defaulted past.",
    decisionEs:
      "Cuando la evidencia no respalda una migración, esa conclusión se documenta — no se ignora.",
    outcomeEn: "Recommendations follow analysis, every time.",
    outcomeEs: "Las recomendaciones vienen siempre después del análisis.",
    delay: 120,
  },
];

const observations = [
  {
    years: "4",
    textEn:
      "Four years supporting multiple concurrent teams — different projects, different stacks. Incidents reported as application defects regularly traced back to platform or infrastructure. Each required a model of the whole before the failing part could be found.",
    textEs:
      "Cuatro años dando soporte a varios equipos a la vez, con proyectos y stacks distintos. Incidentes reportados como fallos de aplicación se remontaban con frecuencia a la plataforma o a la infraestructura. Cada caso exigía un modelo del conjunto antes de dar con la pieza rota.",
    delay: 80,
  },
  {
    years: "3",
    textEn:
      "Earlier: a student team of fewer than twenty, an eleven-month window, their first operational rocket — full lifecycle responsibility across avionics, structures, propulsion and operations, with limited testing and real consequences.",
    textEs:
      "Antes: un equipo estudiantil de menos de veinte personas, once meses de plazo, su primer cohete operativo — responsabilidad completa del ciclo de vida, entre aviónica, estructuras, propulsión y operaciones, con pocas pruebas posibles y consecuencias reales.",
    delay: 140,
  },
];
---

<section id={id} aria-labelledby="evidence-heading" class="evidence-section">
  <div class="evidence-section__inner">
    <SectionLabel label="03 — Evidence" counter="03 / 05" />

    <h2
      data-reveal
      data-d="60"
      id="evidence-heading"
      class="evidence-section__headline"
    >
      <span lang="en"
        >The approach, already applied — in systems already in production.</span
      >
      <span lang="es"
        >El enfoque, ya aplicado — en sistemas que ya estaban en producción.</span
      >
    </h2>

    <p data-reveal data-d="120" class="evidence-section__lead">
      <span lang="en"
        >Environments have included enterprise systems mid-migration, a platform
        team supporting several simulation projects at once, shared
        infrastructure for a large healthcare organisation, and a student
        rocketry team with an eleven-month deadline.</span
      >
      <span lang="es"
        >Los entornos han incluido software empresarial en plena migración, un
        equipo de plataforma dando soporte a varios proyectos de simulación a la
        vez, la infraestructura compartida de una gran organización sanitaria, y
        un equipo estudiantil de cohetería con once meses de plazo.</span
      >
    </p>

    <!-- Case study grid -->
    <div class="evidence-section__cases">
      {
        cases.map((c) => (
          <div data-reveal data-d={c.delay} class="evidence-case">
            <span class="evidence-case__tag">
              <span lang="en">{c.tagEn}</span>
              <span lang="es">{c.tagEs}</span>
            </span>
            <h3 class="evidence-case__title">
              <span lang="en">{c.titleEn}</span>
              <span lang="es">{c.titleEs}</span>
            </h3>
            <div class="evidence-case__field">
              <span class="evidence-case__field-label">
                <span lang="en">Context</span>
                <span lang="es">Contexto</span>
              </span>
              <p class="evidence-case__field-text">
                <span lang="en">{c.contextEn}</span>
                <span lang="es">{c.contextEs}</span>
              </p>
            </div>
            <div class="evidence-case__field">
              <span class="evidence-case__field-label">
                <span lang="en">Decision</span>
                <span lang="es">Decisión</span>
              </span>
              <p class="evidence-case__field-text evidence-case__field-text--decision">
                <span lang="en">{c.decisionEn}</span>
                <span lang="es">{c.decisionEs}</span>
              </p>
            </div>
            <div class="evidence-case__field">
              <span class="evidence-case__field-label evidence-case__field-label--outcome">
                <span lang="en">Outcome</span>
                <span lang="es">Resultado</span>
              </span>
              <p class="evidence-case__field-text evidence-case__field-text--outcome">
                <span lang="en">{c.outcomeEn}</span>
                <span lang="es">{c.outcomeEs}</span>
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Pattern separator -->
    <div data-reveal class="evidence-section__separator">
      <span aria-hidden="true" class="evidence-section__separator-line"></span>
      <span class="evidence-section__separator-text">
        <span lang="en">+6 years of field experience</span>
        <span lang="es">+6 años de experiencia en campo</span>
      </span>
      <span aria-hidden="true" class="evidence-section__separator-line"></span>
    </div>

    <!-- Observations -->
    <div class="evidence-section__observations">
      {
        observations.map((o) => (
          <div data-reveal data-d={o.delay} class="evidence-observation">
            <div class="evidence-observation__value-row">
              <span class="evidence-observation__value">{o.years}</span>
              <span class="evidence-observation__unit">
                <span lang="en">years</span>
                <span lang="es">años</span>
              </span>
            </div>
            <p class="evidence-observation__text">
              <span lang="en">{o.textEn}</span>
              <span lang="es">{o.textEs}</span>
            </p>
          </div>
        ))
      }
    </div>

    <!-- Confirmation -->
    <p data-reveal data-d="80" class="evidence-section__confirmation">
      <span lang="en"
        >The domain, the scale, the constraints — these have differed.
        <span class="evidence-section__confirmation-accent"
          >The approach has not.</span
        ></span
      >
      <span lang="es"
        >El dominio, la escala, las restricciones: eso ha cambiado.
        <span class="evidence-section__confirmation-accent"
          >El enfoque, no.</span
        ></span
      >
    </p>

    <!-- Learning / practice -->
    <div data-reveal data-d="80" class="evidence-section__notes">
      <div class="evidence-section__note">
        <span
          class="evidence-section__note-label evidence-section__note-label--accent"
        >
          <span lang="en">Continuous learning</span>
          <span lang="es">Aprendizaje continuo</span>
        </span>
        <p class="evidence-section__note-text">
          <span lang="en"
            >The technology landscape shifts constantly. Studying unfamiliar
            tools and proving them out before recommending them is treated as a
            professional responsibility, not a reaction to deadlines.</span
          >
          <span lang="es"
            >El panorama tecnológico no se está quieto. Estudiar herramientas
            nuevas y probarlas antes de recomendarlas es una responsabilidad
            profesional, no una reacción a los plazos.</span
          >
        </p>
      </div>
      <div aria-hidden="true" class="evidence-section__note-divider"></div>
      <div class="evidence-section__note">
        <span class="evidence-section__note-label">
          <span lang="en">In practice</span>
          <span lang="es">En la práctica</span>
        </span>
        <p class="evidence-section__note-text">
          <span lang="en"
            >Experience shapes the quality of decisions in unfamiliar systems.
            What it looks like depends on what the system needs.</span
          >
          <span lang="es"
            >La experiencia mejora las decisiones en sistemas desconocidos. Cómo
            se traduce eso depende de lo que cada sistema necesite.</span
          >
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .evidence-section {
    position: relative;
    z-index: 1;
    padding: clamp(6rem, 12vh, 9.375rem) clamp(1.25rem, 4vw, 3.5rem);
  }

  .evidence-section__inner {
    max-width: 1160px;
    margin: 0 auto;
  }

  .evidence-section__headline {
    margin: 0 0 12px;
    max-width: 700px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.375rem, 2.8vw, 2rem);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  .evidence-section__lead {
    margin: 0 0 56px;
    max-width: 720px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink2);
  }

  /* Case study grid */
  .evidence-section__cases {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 720px) {
    .evidence-section__cases {
      grid-template-columns: 1fr;
    }
  }

  .evidence-case {
    padding: 30px 28px;
    border-radius: 18px;
    background: var(--bg2);
    border: 1px solid var(--line);
  }

  .evidence-case__tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 6px 11px;
    border-radius: 7px;
    background: var(--accent-soft);
  }

  .evidence-case__title {
    margin: 16px 0 12px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.1875rem, 2vw, 1.4375rem);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  .evidence-case__field {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-bottom: 12px;
  }

  .evidence-case__field:last-child {
    margin-bottom: 0;
  }

  .evidence-case__field-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .evidence-case__field-label--outcome {
    color: var(--accent);
    opacity: 0.75;
  }

  .evidence-case__field-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink3);
  }

  .evidence-case__field-text--decision {
    font-size: 15.5px;
    color: var(--ink);
    font-weight: 500;
  }

  .evidence-case__field-text--outcome {
    font-size: 15px;
    color: var(--accent);
    font-weight: 700;
  }

  /* Separator */
  .evidence-section__separator {
    margin-top: 40px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .evidence-section__separator-line {
    flex: 1;
    height: 2px;
    background: var(--ink);
  }

  .evidence-section__separator-text {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
  }

  /* Observations */
  .evidence-section__observations {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 720px) {
    .evidence-section__observations {
      grid-template-columns: 1fr;
    }
  }

  .evidence-observation {
    padding: 30px;
    border-radius: 18px;
    background: var(--bg2);
    border: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .evidence-observation__value-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .evidence-observation__value {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 52px;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--accent);
  }

  .evidence-observation__unit {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .evidence-observation__text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink2);
  }

  /* Confirmation */
  .evidence-section__confirmation {
    margin: 40px 0 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 1.9vw, 1.3125rem);
    line-height: 1.5;
    color: var(--ink);
    font-weight: 500;
  }

  .evidence-section__confirmation-accent {
    color: var(--accent);
  }

  /* Learning / practice */
  .evidence-section__notes {
    margin-top: 48px;
    padding: 30px 32px;
    border-radius: 18px;
    background: var(--bg3);
    border: 1px solid var(--line);
  }

  .evidence-section__note {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
  }

  @media (max-width: 640px) {
    .evidence-section__note {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .evidence-section__note-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink3);
    display: inline-block;
    padding: 6px 11px;
    border-radius: 7px;
    background: var(--bg2);
    height: fit-content;
  }

  .evidence-section__note-label--accent {
    color: var(--accent);
    background: var(--accent-soft);
  }

  .evidence-section__note-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink2);
  }

  .evidence-section__note-divider {
    height: 1px;
    background: var(--line);
    margin: 22px 0;
  }
</style>
