---
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  id?: string;
}

const { id } = Astro.props;

const cases = [
  {
    tagEn: "Platform Engineering",
    tagEs: "Ingeniería de plataforma",
    titleEn:
      "A single CI/CD architecture, standardised across environments that had each evolved on their own.",
    titleEs:
      "Una única arquitectura de CI/CD, estandarizada en entornos que hasta entonces evolucionaban cada uno por su cuenta.",
    contextEn:
      "Legacy J2EE applications running across multiple Oracle WebLogic 11g/14c environments, each with its own release process.",
    contextEs:
      "Aplicaciones J2EE heredadas desplegadas en varios entornos Oracle WebLogic 11g/14c, cada uno con su propio proceso de release.",
    decisionEn:
      "Jenkins Shared Libraries centralised build, quality and deployment logic into one reusable architecture; environment configuration was separated from build artefacts, and Maven/Nexus versioning gave every release a consistent lifecycle.",
    decisionEs:
      "Las Jenkins Shared Libraries centralizaron la lógica de build, calidad y despliegue en una arquitectura reutilizable; la configuración de entorno se separó de los artefactos de build, y el versionado con Maven/Nexus dio a cada release un ciclo de vida coherente.",
    outcomeEn:
      "Deployments became predictable and reversible instead of environment-specific rituals — lower operational complexity, and meaningfully less risk in every release.",
    outcomeEs:
      "Los despliegues dejaron de ser rituales propios de cada entorno y pasaron a ser predecibles y reversibles — menos complejidad operativa, y mucho menos riesgo en cada release.",
    delay: 60,
  },
  {
    tagEn: "Platform Architecture",
    tagEs: "Arquitectura de plataforma",
    titleEn:
      "Reusable standards, not one-off fixes, across a regulated healthcare platform.",
    titleEs:
      "Estándares reutilizables, no parches puntuales, en una plataforma sanitaria regulada.",
    contextEn:
      "Enterprise platforms spanning multiple teams, where stability and security leave little room for improvisation.",
    contextEs:
      "Plataformas empresariales que atraviesan varios equipos, donde la estabilidad y la seguridad dejan poco margen para la improvisación.",
    decisionEn:
      "Automation across the software lifecycle and shared standards for Linux-based systems replaced team-by-team improvisation, so modernisation could proceed without destabilising what already worked.",
    decisionEs:
      "La automatización a lo largo del ciclo de vida del software y unos estándares compartidos para los sistemas Linux sustituyeron la improvisación equipo a equipo, permitiendo modernizar sin desestabilizar lo que ya funcionaba.",
    outcomeEn:
      "Fewer inconsistencies for any team to reason about, and modernisation decisions backed by evidence rather than habit.",
    outcomeEs:
      "Menos inconsistencias con las que lidiar en cualquier equipo, y decisiones de modernización respaldadas por evidencia y no por costumbre.",
    delay: 120,
  },
];

const progressionSteps = [
  { en: "Software Engineering", es: "Ingeniería de software" },
  { en: "Distributed Systems", es: "Sistemas distribuidos" },
  { en: "Platform Engineering", es: "Ingeniería de plataforma" },
  { en: "Enterprise Architecture", es: "Arquitectura empresarial" },
  { en: "Technical Leadership", es: "Liderazgo técnico" },
];

const orgs = ["GMV", "Indra", "Sanitas", "Serikat"];
---

<section id={id} aria-labelledby="evidence-heading" class="evidence-section">
  <div class="evidence-section__inner">
    <SectionLabel label="03 — Evidence" counter="03 / 05" />

    <h2
      data-reveal
      data-d="60"
      id="evidence-heading"
      class="evidence-section__headline"
    >
      <span lang="en"
        >The approach, already applied — in systems already in production.</span
      >
      <span lang="es"
        >El enfoque, ya aplicado — en sistemas que ya estaban en producción.</span
      >
    </h2>

    <p data-reveal data-d="120" class="evidence-section__lead">
      <span lang="en"
        >Environments have included a regulated healthcare platform, legacy
        enterprise systems delivered through Oracle WebLogic, and a
        mission-critical satellite monitoring system moved from a monolith to
        microservices.</span
      >
      <span lang="es"
        >Los entornos han incluido una plataforma sanitaria regulada, sistemas
        empresariales heredados desplegados sobre Oracle WebLogic, y un sistema
        de monitorización de satélites en producción, migrado de un monolito a
        microservicios.</span
      >
    </p>

    <!-- Case study grid -->
    <div class="evidence-section__cases">
      {
        cases.map((c) => (
          <div data-reveal data-d={c.delay} class="evidence-case">
            <span class="evidence-case__tag">
              <span lang="en">{c.tagEn}</span>
              <span lang="es">{c.tagEs}</span>
            </span>
            <h3 class="evidence-case__title">
              <span lang="en">{c.titleEn}</span>
              <span lang="es">{c.titleEs}</span>
            </h3>
            <div class="evidence-case__field">
              <span class="evidence-case__field-label">
                <span lang="en">Context</span>
                <span lang="es">Contexto</span>
              </span>
              <p class="evidence-case__field-text">
                <span lang="en">{c.contextEn}</span>
                <span lang="es">{c.contextEs}</span>
              </p>
            </div>
            <div class="evidence-case__field">
              <span class="evidence-case__field-label">
                <span lang="en">Decision</span>
                <span lang="es">Decisión</span>
              </span>
              <p class="evidence-case__field-text evidence-case__field-text--decision">
                <span lang="en">{c.decisionEn}</span>
                <span lang="es">{c.decisionEs}</span>
              </p>
            </div>
            <div class="evidence-case__field">
              <span class="evidence-case__field-label evidence-case__field-label--outcome">
                <span lang="en">Outcome</span>
                <span lang="es">Resultado</span>
              </span>
              <p class="evidence-case__field-text evidence-case__field-text--outcome">
                <span lang="en">{c.outcomeEn}</span>
                <span lang="es">{c.outcomeEs}</span>
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Pattern separator -->
    <div data-reveal class="evidence-section__separator">
      <span aria-hidden="true" class="evidence-section__separator-line"></span>
      <span class="evidence-section__separator-text">
        <span lang="en">From implementation to architectural judgement</span>
        <span lang="es">De la implementación al criterio arquitectónico</span>
      </span>
      <span aria-hidden="true" class="evidence-section__separator-line"></span>
    </div>

    <!-- Progression and breadth -->
    <div class="evidence-section__blocks">
      <div data-reveal data-d="80" class="evidence-block">
        <span class="evidence-block__label">
          <span lang="en">Accumulated capability</span>
          <span lang="es">Capacidad acumulada</span>
        </span>
        <div class="evidence-progression">
          {
            progressionSteps.map((step, i) => (
              <>
                {i > 0 && (
                  <span aria-hidden="true" class="evidence-progression__arrow">
                    →
                  </span>
                )}
                <span
                  class={`evidence-progression__chip ${i === progressionSteps.length - 1 ? "evidence-progression__chip--accent" : ""}`}
                >
                  <span lang="en">{step.en}</span>
                  <span lang="es">{step.es}</span>
                </span>
              </>
            ))
          }
        </div>
        <p class="evidence-block__text">
          <span lang="en"
            >Each stage built on the last: writing the systems, then untangling
            how they fail once distributed, then standardising how they get
            built and shipped, then deciding how they should be structured in
            the first place.</span
          >
          <span lang="es"
            >Cada etapa se apoyó en la anterior: primero escribir los sistemas,
            luego entender cómo fallan al distribuirlos, después estandarizar
            cómo se construyen y despliegan, y por último decidir cómo deben
            estructurarse desde el principio.</span
          >
        </p>
      </div>

      <div
        data-reveal
        data-d="120"
        class="evidence-block evidence-block--breadth"
      >
        <span class="evidence-block__label">
          <span lang="en">Breadth</span>
          <span lang="es">Amplitud</span>
        </span>
        <p class="evidence-block__text evidence-block__text--tight">
          <span lang="en"
            >The same reasoning has applied to a mission-critical satellite
            system, a regulated healthcare platform, legacy enterprise
            environments, and the automation and observability holding them
            together — different domains, the same process of understanding
            before changing.</span
          >
          <span lang="es"
            >El mismo razonamiento se ha aplicado a un sistema de satélites en
            producción, una plataforma sanitaria regulada, entornos
            empresariales heredados, y la automatización y observabilidad que
            los mantiene en marcha — dominios distintos, el mismo proceso de
            entender antes de cambiar.</span
          >
        </p>
      </div>
    </div>

    <!-- Confirmation -->
    <p data-reveal data-d="80" class="evidence-section__confirmation">
      <span lang="en"
        >The domain, the scale, the constraints — these have differed.
        <span class="evidence-section__confirmation-accent"
          >The approach has not.</span
        ></span
      >
      <span lang="es"
        >El dominio, la escala, las restricciones: eso ha cambiado.
        <span class="evidence-section__confirmation-accent"
          >El enfoque, no.</span
        ></span
      >
    </p>

    <!-- Learning / practice -->
    <div data-reveal data-d="80" class="evidence-section__notes">
      <div class="evidence-section__note">
        <span
          class="evidence-section__note-label evidence-section__note-label--accent"
        >
          <span lang="en">Continuous learning</span>
          <span lang="es">Aprendizaje continuo</span>
        </span>
        <p class="evidence-section__note-text">
          <span lang="en"
            >The technology landscape shifts constantly. Studying unfamiliar
            tools and proving them out before recommending them is treated as a
            professional responsibility, not a reaction to deadlines.</span
          >
          <span lang="es"
            >El panorama tecnológico no se está quieto. Estudiar herramientas
            nuevas y probarlas antes de recomendarlas es una responsabilidad
            profesional, no una reacción a los plazos.</span
          >
        </p>
      </div>
      <div aria-hidden="true" class="evidence-section__note-divider"></div>
      <div class="evidence-section__note">
        <span class="evidence-section__note-label">
          <span lang="en">In practice</span>
          <span lang="es">En la práctica</span>
        </span>
        <p class="evidence-section__note-text">
          <span lang="en"
            >Experience shapes the quality of decisions in unfamiliar systems.
            What it looks like depends on what the system needs.</span
          >
          <span lang="es"
            >La experiencia mejora las decisiones en sistemas desconocidos. Cómo
            se traduce eso depende de lo que cada sistema necesite.</span
          >
        </p>
      </div>
    </div>

    <!-- Experience across organisations -->
    <div data-reveal class="evidence-section__orgs">
      <span class="evidence-section__orgs-label">
        <span lang="en"
          >Professional experience across healthcare, enterprise technology and
          aerospace, at organisations including</span
        >
        <span lang="es"
          >Experiencia profesional en sanidad, tecnología empresarial y
          aeroespacial, en organizaciones como</span
        >
      </span>
      <div class="evidence-section__orgs-row">
        {
          orgs.map((org) => (
            <span class="evidence-section__org-logo">{org}</span>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .evidence-section {
    position: relative;
    z-index: 1;
    padding: clamp(6rem, 12vh, 9.375rem) clamp(1.25rem, 4vw, 3.5rem);
  }

  .evidence-section__inner {
    max-width: 1160px;
    margin: 0 auto;
  }

  .evidence-section__headline {
    margin: 0 0 12px;
    max-width: 700px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.375rem, 2.8vw, 2rem);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  .evidence-section__lead {
    margin: 0 0 56px;
    max-width: 720px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink2);
  }

  /* Case study grid */
  .evidence-section__cases {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 720px) {
    .evidence-section__cases {
      grid-template-columns: 1fr;
    }
  }

  .evidence-case {
    padding: 30px 28px;
    border-radius: 18px;
    background: var(--bg2);
    border: 1px solid var(--line);
  }

  .evidence-case__tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 6px 11px;
    border-radius: 7px;
    background: var(--accent-soft);
  }

  .evidence-case__title {
    margin: 16px 0 12px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.1875rem, 2vw, 1.4375rem);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  .evidence-case__field {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-bottom: 12px;
  }

  .evidence-case__field:last-child {
    margin-bottom: 0;
  }

  .evidence-case__field-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .evidence-case__field-label--outcome {
    color: var(--accent);
    opacity: 0.75;
  }

  .evidence-case__field-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink3);
  }

  .evidence-case__field-text--decision {
    font-size: 15.5px;
    color: var(--ink);
    font-weight: 500;
  }

  .evidence-case__field-text--outcome {
    font-size: 15px;
    color: var(--accent);
    font-weight: 700;
  }

  /* Separator */
  .evidence-section__separator {
    margin-top: 40px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .evidence-section__separator-line {
    flex: 1;
    height: 2px;
    background: var(--ink);
  }

  .evidence-section__separator-text {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
  }

  /* Progression / breadth */
  .evidence-section__blocks {
    margin-top: 32px;
  }

  .evidence-block {
    padding: 30px 32px;
    border-radius: 18px;
    background: var(--bg2);
    border: 1px solid var(--line);
  }

  .evidence-block--breadth {
    margin-top: 24px;
  }

  .evidence-block__label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .evidence-block__text {
    margin: 18px 0 0;
    max-width: 760px;
    font-family: var(--font-body);
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink2);
  }

  .evidence-block__text--tight {
    margin-top: 12px;
  }

  .evidence-progression {
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .evidence-progression__chip {
    padding: 7px 13px;
    border-radius: 8px;
    background: var(--bg3);
    border: 1px solid var(--line);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12.5px;
    line-height: 1.2;
    color: var(--ink2);
    white-space: nowrap;
  }

  .evidence-progression__chip--accent {
    background: linear-gradient(160deg, var(--accent), var(--accent-2));
    border-color: transparent;
    color: #fff;
  }

  .evidence-progression__arrow {
    color: var(--ink3);
    font-size: 13px;
  }

  /* Confirmation */
  .evidence-section__confirmation {
    margin: 40px 0 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 1.9vw, 1.3125rem);
    line-height: 1.5;
    color: var(--ink);
    font-weight: 500;
  }

  .evidence-section__confirmation-accent {
    color: var(--accent);
  }

  /* Learning / practice */
  .evidence-section__notes {
    margin-top: 48px;
    padding: 30px 32px;
    border-radius: 18px;
    background: var(--bg3);
    border: 1px solid var(--line);
  }

  .evidence-section__note {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
  }

  @media (max-width: 640px) {
    .evidence-section__note {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .evidence-section__note-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink3);
    display: inline-block;
    padding: 6px 11px;
    border-radius: 7px;
    background: var(--bg2);
    height: fit-content;
  }

  .evidence-section__note-label--accent {
    color: var(--accent);
    background: var(--accent-soft);
  }

  .evidence-section__note-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink2);
  }

  .evidence-section__note-divider {
    height: 1px;
    background: var(--line);
    margin: 22px 0;
  }

  /* Experience across organisations */
  .evidence-section__orgs {
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  .evidence-section__orgs-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12.5px;
    line-height: 1;
    color: var(--ink3);
  }

  .evidence-section__orgs-row {
    margin-top: 14px;
    display: flex;
    align-items: center;
    gap: clamp(20px, 3vw, 34px);
    flex-wrap: wrap;
  }

  .evidence-section__org-logo {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 15px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--ink3);
    filter: grayscale(1);
  }
</style>
