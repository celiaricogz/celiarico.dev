---
import ProblemCard from "../features/content/ProblemCard.astro";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  id?: string;
}

const { id } = Astro.props;

const problems = [
  {
    number: "01",
    textEn: "Architecture that grew faster than it was ever designed.",
    textEs: "Una arquitectura que creció más rápido de lo que nunca se diseñó.",
    delay: 60,
  },
  {
    number: "02",
    textEn: "Deployments that everyone is quietly a little afraid of.",
    textEs:
      "Despliegues de los que todos, en silencio, tienen un poco de miedo.",
    delay: 120,
  },
  {
    number: "03",
    textEn: "Critical knowledge that lives in just one person's head.",
    textEs: "Conocimiento crítico que vive solo en la cabeza de una persona.",
    delay: 180,
  },
  {
    number: "04",
    textEn: "Dependencies no one can explain but everyone is afraid to touch.",
    textEs: "Dependencias que nadie puede explicar pero que todos temen tocar.",
    delay: 240,
  },
];

const consequences = [
  {
    en: "Delivery cycles slow as change becomes increasingly cautious.",
    es: "Los ciclos de entrega se ralentizan a medida que el cambio se vuelve cada vez más cauteloso.",
  },
  {
    en: "Operational risk accumulates with every release.",
    es: "El riesgo operativo se acumula con cada versión.",
  },
  {
    en: "Architectural decisions become collective negotiations rather than informed choices.",
    es: "Las decisiones de arquitectura se convierten en negociaciones colectivas en lugar de elecciones informadas.",
  },
  {
    en: "Institutional knowledge concentrates in two or three individuals.",
    es: "El conocimiento institucional se concentra en dos o tres personas.",
  },
  {
    en: "Maintaining the existing system costs more than moving it forward.",
    es: "Mantener el sistema existente cuesta más que hacerlo avanzar.",
  },
];
---

<section id={id} aria-labelledby="problem-heading" class="problem-section">
  <div class="problem-section__inner">
    <SectionLabel label="01 — The Problem" counter="01 / 05" />

    <h2
      data-reveal
      data-d="60"
      id="problem-heading"
      class="problem-section__headline"
    >
      <span lang="en"
        >Complex systems rarely break all at once.
        <span class="problem-section__headline-muted"
          >They stop making sense, gradually.</span
        ></span
      >
      <span lang="es"
        >Los sistemas complejos rara vez se rompen de golpe.
        <span class="problem-section__headline-muted"
          >Dejan de tener sentido, poco a poco.</span
        ></span
      >
    </h2>

    <p data-reveal data-d="120" class="problem-section__lead">
      <span lang="en"
        >Most teams know something has shifted before they can describe what.
        Changes feel riskier. Decisions feel less certain. The system still
        works — but it no longer feels fully understood.</span
      >
      <span lang="es"
        >La mayoría de los equipos perciben que algo ha cambiado antes de poder
        describir qué. Los cambios se sienten más arriesgados. Las decisiones,
        menos seguras. El sistema sigue funcionando, pero ya no se entiende del
        todo.</span
      >
    </p>

    <div class="problem-section__split">
      <!-- Problem spec list -->
      <div class="problem-section__list">
        {problems.map((p) => <ProblemCard {...p} />)}
      </div>

      <!-- Widening gap diagram -->
      <div
        data-reveal
        data-d="160"
        class="problem-section__chart"
        role="img"
        data-label-en="Line chart showing system complexity rising steeply over time while shared understanding rises only slowly, leaving a widening gap between the two"
        data-label-es="Gráfico de líneas que muestra la complejidad del sistema aumentando con fuerza mientras la comprensión compartida crece muy despacio, dejando una brecha cada vez mayor entre ambas"
      >
        <span class="problem-section__chart-title">
          <span lang="en">The widening gap</span>
          <span lang="es">La brecha que se amplía</span>
        </span>
        <svg
          viewBox="0 0 320 172"
          class="problem-section__chart-svg"
          aria-hidden="true"
        >
          <line
            x1="10"
            y1="150"
            x2="265"
            y2="150"
            stroke="var(--line)"
            stroke-width="1"></line>
          <polygon
            points="10,150 95,115 180,72 265,22 265,108 180,118 95,128 10,148"
            fill="var(--accent-soft)"></polygon>
          <polyline
            points="10,148 95,128 180,118 265,108"
            fill="none"
            stroke="var(--ink3)"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-dasharray="1 6"></polyline>
          <polyline
            points="10,150 95,115 180,72 265,22"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></polyline>
          <circle cx="265" cy="22" r="4" fill="var(--accent)"></circle>
          <circle cx="265" cy="108" r="4" fill="var(--ink3)"></circle>
          <line
            x1="284"
            y1="22"
            x2="284"
            y2="108"
            stroke="var(--ink3)"
            stroke-width="1"></line>
          <line
            x1="280"
            y1="22"
            x2="288"
            y2="22"
            stroke="var(--ink3)"
            stroke-width="1"></line>
          <line
            x1="280"
            y1="108"
            x2="288"
            y2="108"
            stroke="var(--ink3)"
            stroke-width="1"></line>
          <text x="294" y="69" class="problem-section__chart-gap-label"
            ><tspan lang="en">gap</tspan><tspan lang="es">brecha</tspan></text
          >
          <text x="10" y="163" class="problem-section__chart-tick">t0</text>
          <text x="88" y="163" class="problem-section__chart-tick">t1</text>
          <text x="173" y="163" class="problem-section__chart-tick">t2</text>
          <text x="255" y="163" class="problem-section__chart-tick">t3</text>
        </svg>
        <div class="problem-section__chart-legend">
          <span class="problem-section__chart-legend-item">
            <span
              class="problem-section__chart-swatch problem-section__chart-swatch--accent"
              aria-hidden="true"></span>
            <span lang="en">System complexity</span>
            <span lang="es">Complejidad del sistema</span>
          </span>
          <span class="problem-section__chart-legend-item">
            <span class="problem-section__chart-swatch" aria-hidden="true"
            ></span>
            <span lang="en">Shared understanding</span>
            <span lang="es">Comprensión compartida</span>
          </span>
        </div>
      </div>
    </div>

    <!-- Why it happens / Why it compounds -->
    <div class="problem-section__rows">
      <div data-reveal data-d="80" class="problem-section__row">
        <span class="problem-section__row-label">
          <span lang="en">Why it happens</span>
          <span lang="es">Por qué ocurre</span>
        </span>
        <p class="problem-section__row-text">
          <span lang="en"
            >This is not a sign of bad teams or poor decisions. The pattern is
            consistent: as systems grow, the shared understanding of how they
            actually behave does not grow with them. Each decision is made with
            an incomplete picture of the whole. The system evolves. The
            understanding of it does not.</span
          >
          <span lang="es"
            >Esto no es señal de malos equipos ni de malas decisiones. El patrón
            es constante: a medida que los sistemas crecen, la comprensión
            compartida de cómo se comportan realmente no crece con ellos. Cada
            decisión se toma con una imagen incompleta del conjunto. El sistema
            evoluciona. La comprensión de él, no.</span
          >
        </p>
      </div>
      <div data-reveal data-d="140" class="problem-section__row">
        <span class="problem-section__row-label">
          <span lang="en">Why it compounds</span>
          <span lang="es">Por qué se agrava</span>
        </span>
        <p class="problem-section__row-text">
          <span lang="en"
            >What makes this condition difficult to resolve from within is that
            it compounds. Each change made under incomplete understanding
            creates new uncertainty. The next decision becomes harder to assess.
            Confidence in the outcome decreases. The cost of every change
            quietly rises — not because the technology is fundamentally broken,
            but because the gap between how the system is believed to work and
            how it actually works widens with every change.</span
          >
          <span lang="es"
            >Lo que hace difícil resolver esta condición desde dentro es que se
            agrava. Cada cambio hecho con una comprensión incompleta genera
            nueva incertidumbre. La siguiente decisión se vuelve más difícil de
            evaluar. La confianza en el resultado disminuye. El costo de cada
            cambio aumenta silenciosamente, no porque la tecnología esté
            fundamentalmente rota, sino porque la brecha entre cómo se cree que
            funciona el sistema y cómo funciona realmente se amplía con cada
            cambio.</span
          >
        </p>
      </div>
    </div>

    <!-- Consequence timeline -->
    <div class="problem-section__consequences-wrap">
      <span data-reveal class="problem-section__consequences-label">
        <span lang="en">This shows up as</span>
        <span lang="es">Esto se manifiesta como</span>
      </span>
      <div class="problem-section__timeline">
        <div aria-hidden="true" class="problem-section__timeline-track"></div>
        {
          consequences.map((c, i) => (
            <div
              data-reveal
              data-d={i * 60}
              class="problem-section__consequence"
            >
              <span
                aria-hidden="true"
                class="problem-section__consequence-dot"
              />
              <p class="problem-section__consequence-text">
                <span lang="en">{c.en}</span>
                <span lang="es">{c.es}</span>
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Reframe -->
    <p data-reveal data-d="80" class="problem-section__reframe">
      <span lang="en"
        >This situation is not inevitable. But it does not resolve through
        faster delivery, better tooling, or more documentation. It requires a
        different starting point — understanding how the system actually
        behaves, before anything else changes.</span
      >
      <span lang="es"
        >Esta situación no es inevitable. Pero no se resuelve entregando más
        rápido, con mejores herramientas o más documentación. Requiere un punto
        de partida distinto: entender cómo se comporta realmente el sistema,
        antes de cambiar cualquier otra cosa.</span
      >
    </p>
  </div>
</section>

<style>
  .problem-section {
    position: relative;
    z-index: 1;
    padding: clamp(6rem, 12vh, 9.375rem) clamp(1.25rem, 4vw, 3.5rem);
  }

  .problem-section__inner {
    max-width: 1160px;
    margin: 0 auto;
  }

  .problem-section__headline {
    margin: 0;
    max-width: 820px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .problem-section__headline-muted {
    color: var(--ink3);
  }

  .problem-section__lead {
    margin: 22px 0 60px;
    max-width: 600px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink2);
  }

  /* Split: list + chart */
  .problem-section__split {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 980px) {
    .problem-section__split {
      grid-template-columns: 1fr;
    }
  }

  .problem-section__list {
    border-top: 1px solid var(--line);
  }

  .problem-section__chart {
    padding: 26px;
    border-radius: 16px;
    background: var(--bg2);
    border: 1px solid var(--line);
  }

  .problem-section__chart-title {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .problem-section__chart-svg {
    width: 100%;
    height: auto;
    margin-top: 14px;
    overflow: visible;
  }

  .problem-section__chart-gap-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    fill: var(--accent);
  }

  .problem-section__chart-tick {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink3);
  }

  .problem-section__chart-legend {
    margin-top: 12px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .problem-section__chart-legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink2);
  }

  .problem-section__chart-swatch {
    width: 14px;
    height: 3px;
    border-radius: 2px;
    background: var(--ink3);
  }

  .problem-section__chart-swatch--accent {
    background: var(--accent);
  }

  /* Why it happens / compounds rows */
  .problem-section__rows {
    margin-top: 64px;
  }

  .problem-section__row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    padding: 30px 0;
    border-top: 1px solid var(--line);
  }

  @media (max-width: 980px) {
    .problem-section__row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .problem-section__row-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    display: inline-block;
    padding: 6px 11px;
    border-radius: 7px;
    background: var(--accent-soft);
    height: fit-content;
  }

  .problem-section__row-text {
    margin: 0;
    max-width: 640px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink2);
  }

  /* Consequence timeline */
  .problem-section__consequences-wrap {
    margin-top: 60px;
  }

  .problem-section__consequences-label {
    display: block;
    margin-bottom: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .problem-section__timeline {
    position: relative;
    padding-left: 26px;
  }

  .problem-section__timeline-track {
    position: absolute;
    left: 3px;
    top: 8px;
    bottom: 8px;
    width: 1.5px;
    background: linear-gradient(180deg, var(--accent), var(--line2));
  }

  .problem-section__consequence {
    position: relative;
    padding-bottom: 22px;
  }

  .problem-section__consequence:last-child {
    padding-bottom: 0;
  }

  .problem-section__consequence-dot {
    position: absolute;
    left: -26px;
    top: 4px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    display: block;
  }

  .problem-section__consequence-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink2);
  }

  /* Reframe */
  .problem-section__reframe {
    margin: 56px 0 0;
    font-family: var(--font-body);
    font-size: clamp(1.1875rem, 2.1vw, 1.5rem);
    line-height: 1.5;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.01em;
    padding-top: 28px;
    border-top: 2px solid var(--ink);
  }
</style>
