---
interface Props {
  variant?: "primary" | "secondary";
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  loading?: boolean;
}

const {
  variant = "primary",
  type = "button",
  disabled = false,
  loading = false,
} = Astro.props;

const isDisabled = disabled || loading;

const base =
  "inline-flex items-center justify-center px-5 py-3 text-body font-body leading-normal rounded-md cursor-pointer transition-colors duration-fast ease-out motion-reduce:transition-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring active:opacity-90 disabled:cursor-not-allowed disabled:opacity-50";

const variants: Record<"primary" | "secondary", string> = {
  primary: "bg-accent text-accent-foreground hover:enabled:bg-accent-hover",
  secondary:
    "border border-border text-foreground hover:enabled:bg-background-subtle",
};

const classes = `${base} ${variants[variant]}`;
---

<button
  type={type}
  disabled={isDisabled}
  aria-busy={loading ? "true" : undefined}
  class={classes}
>
  <slot />
</button>
