---
import Caption from "../../../typography/Caption.astro";
import Stack from "../../../primitives/Stack.astro";

interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<Stack as="figure" gap="1">
  <span class="font-body text-h1 text-accent leading-tight tracking-tight"
    >{value}</span
  >
  <Caption as="figcaption">{label}</Caption>
</Stack>
