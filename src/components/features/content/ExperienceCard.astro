---
import Body from "../../../typography/Body.astro";
import Heading from "../../../typography/Heading.astro";
import Badge from "../../../ui/Badge.astro";
import Stack from "../../../primitives/Stack.astro";

interface Props {
  title: string;
  description: string;
  tags?: string[];
}

const { title, description, tags } = Astro.props;
---

<article>
  <Stack gap="3">
    <Heading level={3}>{title}</Heading>
    <Body>{description}</Body>
    {
      tags && tags.length > 0 && (
        <ul class="m-0 flex list-none flex-wrap gap-2 p-0">
          {tags.map((tag) => (
            <li>
              <Badge variant="subtle">{tag}</Badge>
            </li>
          ))}
        </ul>
      )
    }
  </Stack>
</article>
