---
import type { SpacingScale } from "../../types/tokens";

interface Props {
  as?: string;
  columns?: 2 | 3 | 4;
  gap?: SpacingScale;
}

const { as: Tag = "div", columns = 3, gap = "6" } = Astro.props;

const gapClasses: Record<SpacingScale, string> = {
  "0": "gap-0",
  "1": "gap-1",
  "2": "gap-2",
  "3": "gap-3",
  "4": "gap-4",
  "5": "gap-5",
  "6": "gap-6",
  "8": "gap-8",
  "10": "gap-10",
  "12": "gap-12",
  "16": "gap-16",
  "20": "gap-20",
  "24": "gap-24",
  "32": "gap-32",
};

const columnClasses: Record<2 | 3 | 4, string> = {
  2: "grid-cols-1 md:grid-cols-2",
  3: "grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
  4: "grid-cols-1 md:grid-cols-2 lg:grid-cols-4",
};
---

<Tag class={`grid ${columnClasses[columns]} ${gapClasses[gap]}`}>
  <slot />
</Tag>
