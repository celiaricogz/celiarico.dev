---
import type { SpacingScale } from "../../types/tokens";

interface Props {
  as?: string;
  gap?: SpacingScale;
  justify?: "start" | "center" | "end";
}

const { as: Tag = "div", gap = "4", justify = "start" } = Astro.props;

const gapClasses: Record<SpacingScale, string> = {
  "0": "gap-0",
  "1": "gap-1",
  "2": "gap-2",
  "3": "gap-3",
  "4": "gap-4",
  "5": "gap-5",
  "6": "gap-6",
  "8": "gap-8",
  "10": "gap-10",
  "12": "gap-12",
  "16": "gap-16",
  "20": "gap-20",
  "24": "gap-24",
  "32": "gap-32",
};

const justifyClasses: Record<"start" | "center" | "end", string> = {
  start: "justify-start",
  center: "justify-center",
  end: "justify-end",
};
---

<Tag
  class={`flex flex-wrap items-center ${gapClasses[gap]} ${justifyClasses[justify]}`}
>
  <slot />
</Tag>
