---
import type { SpacingScale } from "../../types/tokens";

interface Props {
  as?: string;
  padding?: SpacingScale;
  paddingX?: SpacingScale;
  paddingY?: SpacingScale;
}

const { as: Tag = "div", padding, paddingX, paddingY } = Astro.props;

const paddingClasses: Record<SpacingScale, string> = {
  "0": "p-0",
  "1": "p-1",
  "2": "p-2",
  "3": "p-3",
  "4": "p-4",
  "5": "p-5",
  "6": "p-6",
  "8": "p-8",
  "10": "p-10",
  "12": "p-12",
  "16": "p-16",
  "20": "p-20",
  "24": "p-24",
  "32": "p-32",
};

const paddingXClasses: Record<SpacingScale, string> = {
  "0": "px-0",
  "1": "px-1",
  "2": "px-2",
  "3": "px-3",
  "4": "px-4",
  "5": "px-5",
  "6": "px-6",
  "8": "px-8",
  "10": "px-10",
  "12": "px-12",
  "16": "px-16",
  "20": "px-20",
  "24": "px-24",
  "32": "px-32",
};

const paddingYClasses: Record<SpacingScale, string> = {
  "0": "py-0",
  "1": "py-1",
  "2": "py-2",
  "3": "py-3",
  "4": "py-4",
  "5": "py-5",
  "6": "py-6",
  "8": "py-8",
  "10": "py-10",
  "12": "py-12",
  "16": "py-16",
  "20": "py-20",
  "24": "py-24",
  "32": "py-32",
};

const classList: string[] = [];
if (padding) classList.push(paddingClasses[padding]);
if (paddingX) classList.push(paddingXClasses[paddingX]);
if (paddingY) classList.push(paddingYClasses[paddingY]);
const classes = classList.join(" ") || undefined;
---

<Tag class={classes}>
  <slot />
</Tag>
